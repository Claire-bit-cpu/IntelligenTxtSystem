package com.example.IntelligentRobot;

import org.springframework.data.redis.core.RedisTemplate;
import org.springframework.web.bind.annotation.*;

import java.util.concurrent.TimeUnit;

/**
 * Redis 连接测试接口
 * 启动项目后，用以下接口验证 Redis 是否配置成功：
 *
 * 1. 写入测试：POST /api/redis/test/set?key=foo&value=bar
 * 2. 读取测试：GET /api/redis/test/get?key=foo
 * 3. 删除测试：DELETE /api/redis/test/del?key=foo
 */
@RestController
@RequestMapping("/api/redis/test")
public class RedisTestController {

    private final RedisTemplate<String, Object> redisTemplate;

    public RedisTestController(RedisTemplate<String, Object> redisTemplate) {
        this.redisTemplate = redisTemplate;
    }

    /**
     * 写入 Key-Value，默认 300 秒过期
     */
    @PostMapping("/set")
    public String set(
            @RequestParam String key,
            @RequestParam String value,
            @RequestParam(defaultValue = "300") long expireSeconds) {

        redisTemplate.opsForValue().set(key, value, expireSeconds, TimeUnit.SECONDS);
        return "OK：已写入 Redis，key=" + key + "，过期时间=" + expireSeconds + "秒";
    }

    /**
     * 读取 Key 对应的 Value
     */
    @GetMapping("/get")
    public String get(@RequestParam String key) {
        Object value = redisTemplate.opsForValue().get(key);
        if (value == null) {
            return "Redis 中不存在 key=" + key;
        }
        return "key=" + key + "，value=" + value;
    }

    /**
     * 删除 Key
     */
    @DeleteMapping("/del")
    public String del(@RequestParam String key) {
        Boolean deleted = redisTemplate.delete(key);
        return Boolean.TRUE.equals(deleted) ? "OK：已删除 key=" + key : "Redis 中不存在 key=" + key;
    }
}
